---
// src/components/Services.astro

const services = [
  {
    title: "Volvo 2.5T Excavator",
    desc: "Power meets versatility. Perfect for groundwork, landscaping, and site clearance. Available with a pecker attachment for breaking tough ground.",
    points: ["Breaker/Pecker Available", "High Digging Force", "Perfect for Groundworks"],
    // Excavator/Digger Icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-3-3m0 0l-3-3m3 3l3 3m-3-3l-3 3M6 21H3a2 2 0 01-2-2v-4a2 2 0 012-2h3M9 21h12a2 2 0 002-2v-4a2 2 0 00-2-2H9M6 13V5a2 2 0 012-2h4a2 2 0 012 2v8M10 3v10M14 7h4l3 3"></path></svg>`,
    tag: "Heavy Duty"
  },
  {
    title: "Kubota 0.8T Micro Digger",
    desc: "Small but mighty. Compact and powerful, designed specifically for getting through narrow spaces like doorways and garden gates.",
    points: ["Fits Through Doorways", "Ideal for Indoor Work", "Restricted Access Ready"],
    // Compact/Target Icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>`,
    tag: "Restricted Access"
  },
  {
    title: "Groundworks & Demolition",
    desc: "Equipped to tackle the tough jobs. From ripping up old driveways and concrete slabs to prepping sites for extensions and new builds.",
    points: ["Site Clearance", "Concrete Breaking", "Extension Prep"],
    // Hammer/Breaker Icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>`,
    tag: "Specialist"
  },
  {
    title: "Flexible Hire Options",
    desc: "Whether you need a machine for a single day of DIY or a long-term commercial project, we offer competitive rates and local delivery.",
    points: ["Daily & Weekly Rates", "Free Local Delivery", "Well-Maintained Fleet"],
    // Calendar/Clock Icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><circle cx="12" cy="16" r="2"></circle></svg>`,
    tag: "Affordable"
  }
];
---

<section id="services" class="relative py-24 bg-brand-white px-6 border-b-4 border-brand-black z-20">
  
  <div class="absolute inset-0 opacity-[0.03] bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto">
    
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-brand-slate text-white px-4 py-1.5 font-bold text-sm mb-4 rounded-sm uppercase tracking-widest shadow-[4px_4px_0px_#0a0a0a]">
        Our Fleet & Capabilities
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-brand-black uppercase italic tracking-tight mb-6">
        High Quality <span class="text-brand-blue underline decoration-brand-black decoration-4 underline-offset-8">Plant Machinery</span>
      </h2>
      <p class="text-lg text-gray-600 font-medium">
        From tight garden access to heavy-duty site demolition, we provide reliable, well-maintained equipment to get your job done safely and efficiently.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        /* Updated shadow color to match the new RHO brand-blue (#18528c) */
        <div class="group relative bg-white border-2 border-brand-black p-8 flex flex-col h-full transition-all duration-300 shadow-[6px_6px_0px_#18528c] hover:shadow-[0px_0px_0px_#18528c] hover:translate-x-[6px] hover:translate-y-[6px]">
          
          <div class="absolute -top-3 right-4 bg-brand-blue text-white text-xs font-bold uppercase tracking-widest px-3 py-1 border border-brand-black shadow-[2px_2px_0px_#0a0a0a]">
            {service.tag}
          </div>

          <div class="w-16 h-16 bg-brand-white border-2 border-brand-black text-brand-black flex items-center justify-center mb-6 shadow-[3px_3px_0px_#18528c] group-hover:bg-brand-blue group-hover:text-white transition-colors duration-300">
            <Fragment set:html={service.icon} />
          </div>

          <h3 class="text-2xl font-bold text-brand-black mb-3 uppercase italic leading-tight">
            {service.title}
          </h3>
          <p class="text-sm text-gray-600 font-medium mb-6 flex-grow">
            {service.desc}
          </p>

          <ul class="space-y-3 mb-8 border-t border-gray-100 pt-6">
            {service.points.map((point) => (
              <li class="flex items-start gap-3 text-sm font-bold text-brand-black">
                <svg class="w-5 h-5 text-brand-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                {point}
              </li>
            ))}
          </ul>

          <button onclick="window.openQuoteModal()" class="w-full mt-auto cursor-pointer bg-brand-black text-white py-3 font-bold uppercase tracking-widest text-sm border-2 border-brand-black hover:bg-brand-blue hover:border-brand-blue transition-colors duration-300">
            Check Availability
          </button>
        </div>
      ))}
    </div>

  </div>
</section>