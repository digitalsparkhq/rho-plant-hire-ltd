---
// src/components/Header.astro
const pathname = Astro.url.pathname;
---

<header class="relative z-50 w-full bg-brand-white shadow-lg border-b-4 border-brand-blue text-brand-dark-blue">
  
  <div class="hidden md:flex justify-between items-center max-w-7xl mx-auto px-6 py-4">
    <a href="/" class="flex-shrink-0">
      <img src="/images/logo.png" alt="Weatherproof Roofing Solutions Ltd" class="h-20 lg:h-24 w-auto object-contain" />
    </a>

    <div class="flex items-center gap-8">
      <div class="flex items-center gap-6">
        <a href="tel:01482961500" class="flex items-center gap-2 text-brand-black hover:text-brand-blue transition-colors font-bold text-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          01482 961500
        </a>
        <a href="mailto:weatherproofrsltd@gmail.com" class="flex items-center gap-2 hover:text-brand-blue transition-colors font-semibold">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          Email Us
        </a>
      </div>
      
      <div class="flex items-center gap-4 border-l-2 pl-6 border-brand-dark-blue/20">
        <a href="https://wa.me/447949417242" target="_blank" class="text-[#25D366] hover:scale-110 transition-transform">
          <svg class="w-8 h-8 drop-shadow" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="https://www.facebook.com/people/Weatherproof-roofing-solutions-ltd/100086932397252/" target="_blank" class="text-[#1877F2] hover:scale-110 transition-transform">
          <svg class="w-8 h-8 drop-shadow" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.instagram.com/weatherproof_roofing_solutions/" target="_blank" class="text-[#E1306C] hover:scale-110 transition-transform">
          <svg class="w-8 h-8 drop-shadow" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668 2.014 15.259 2 12 2ZM12 7.838a6.162 6.162 0 110 12.324 6.162 6.162 0 010-12.324Zm0 10.162a4 4 0 100-8 4 4 0 000 8Zm6.406-11.845a1.44 1.44 0 110 2.881 1.44 1.44 0 010-2.881Z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="hidden md:block h-px w-full bg-brand-dark-blue/10"></div>

  <div class="hidden md:flex items-center max-w-7xl mx-auto px-6 py-4">
    <nav class="flex items-center gap-8 font-bold text-xl text-brand-dark-blue">
      <a href="/" class={`hover:text-brand-blue transition-colors pb-1 border-b-2 ${pathname === '/' ? 'text-brand-blue border-brand-blue' : 'border-transparent'}`}>Home</a>
      <a href="/#about" class="hover:text-brand-blue transition-colors pb-1 border-b-2 border-transparent">About</a>
      <a href="/#services" class="hover:text-brand-blue transition-colors pb-1 border-b-2 border-transparent">Services</a>
      <a href="/#gallery" class="hover:text-brand-blue transition-colors pb-1 border-b-2 border-transparent">Gallery</a>
      <a href="/contact" class={`hover:text-brand-blue transition-colors pb-1 border-b-2 ${pathname === '/contact' ? 'text-brand-blue border-brand-blue' : 'border-transparent'}`}>Contact</a>
      
      <button onclick="window.openQuoteModal()" class="cursor-pointer ml-4 bg-brand-blue text-white px-6 py-2.5 rounded hover:bg-blue-600 hover:-translate-y-1 transition-all duration-300 uppercase tracking-widest shadow-md hover:shadow-lg text-lg">
        Free Quote
      </button>
    </nav>
  </div>

  <div class="md:hidden flex justify-between items-center px-4 py-3">
    <a href="/">
      <img src="/images/logo.png" alt="Weatherproof Roofing Solutions Ltd" class="h-16 w-auto object-contain" />
    </a>
    <button id="mobile-menu-btn" class="cursor-pointer p-2 focus:outline-none hover:text-brand-blue transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-brand-dark-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" /></svg>
    </button>
  </div>
</header>

<div id="mobile-drawer" class="fixed inset-y-0 right-0 w-72 bg-brand-white shadow-2xl transform translate-x-full transition-transform duration-300 z-[60] flex flex-col md:hidden border-l-4 border-brand-blue">
  <div class="p-4 flex justify-end border-b border-brand-dark-blue/20">
    <button id="close-drawer-btn" class="cursor-pointer p-2 hover:text-brand-blue transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-dark-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
  
  <nav id="mobile-nav-links" class="flex flex-col p-6 gap-6 flex-grow font-bold text-xl text-brand-dark-blue">
    <a href="/" class={`hover:text-brand-blue ${pathname === '/' ? 'text-brand-blue underline decoration-2 underline-offset-4' : ''}`}>Home</a>
    <a href="/#about" class="hover:text-brand-blue">About</a>
    <a href="/#services" class="hover:text-brand-blue">Services</a>
    <a href="/#gallery" class="hover:text-brand-blue">Gallery</a>
    <a href="/contact" class={`hover:text-brand-blue ${pathname === '/contact' ? 'text-brand-blue underline decoration-2 underline-offset-4' : ''}`}>Contact</a>
  </nav>

  <div class="p-6 border-t border-brand-dark-blue/20 bg-brand-white/50">
    <button onclick="window.openQuoteModal(); document.getElementById('mobile-drawer').classList.add('translate-x-full');" class="cursor-pointer w-full bg-brand-blue text-white py-4 rounded font-bold text-lg mb-4 text-center uppercase shadow-md hover:shadow-lg hover:bg-blue-600 hover:-translate-y-1 transition-all duration-300">
      Free Quote
    </button>
    
    <a href="tel:01482961500" class="flex justify-center items-center gap-2 text-brand-black hover:text-brand-blue transition-colors font-bold text-lg mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
      01482 961500
    </a>

    <div class="flex justify-center gap-6">
      <a href="https://wa.me/447949417242" class="text-[#25D366] hover:scale-110 transition-transform"><svg class="w-8 h-8 drop-shadow" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472... (Keep original path)"/></svg></a>
      <a href="https://www.facebook.com/people/Weatherproof-roofing-solutions-ltd/100086932397252/" class="text-[#1877F2] hover:scale-110 transition-transform"><svg class="w-8 h-8 drop-shadow" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073... (Keep original path)"/></svg></a>
      <a href="https://www.instagram.com/weatherproof_roofing_solutions/" class="text-[#E1306C] hover:scale-110 transition-transform"><svg class="w-8 h-8 drop-shadow" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163... (Keep original path)"/></svg></a>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-drawer-btn');
  const drawer = document.getElementById('mobile-drawer');
  
  // Select all anchor tags inside the mobile navigation links
  const mobileNavLinks = document.querySelectorAll('#mobile-nav-links a');

  menuBtn?.addEventListener('click', () => {
    drawer?.classList.remove('translate-x-full');
  });

  closeBtn?.addEventListener('click', () => {
    drawer?.classList.add('translate-x-full');
  });

  // Automatically close the drawer when any navigation link is clicked
  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      drawer?.classList.add('translate-x-full');
    });
  });
</script>