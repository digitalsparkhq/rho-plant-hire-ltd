---
// src/components/Hero.astro

const images = [
  '/images/hero1.jpg', 
  '/images/hero2.jpg', 
  '/images/hero3.jpg'
];
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden border-b-4 border-brand-blue">
  
  <div class="absolute inset-0 z-0 bg-brand-black overflow-hidden">
    {images.map((img, index) => (
      <div 
        class={`hero-bg bg-${index + 1}`} 
        style={`background-image: url('${img}');`}
      ></div>
    ))}
  </div>

  <div class="absolute inset-0 bg-gradient-to-r from-brand-black/90 via-brand-dark-blue/50 to-transparent z-10 pointer-events-none mix-blend-multiply"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-brand-black/60 to-transparent z-10 pointer-events-none"></div>

  <div class="relative z-30 max-w-7xl mx-auto px-6 py-20 w-full">
    <div class="max-w-3xl">
      
      <div class="inline-flex items-center gap-2 bg-brand-dark-blue/80 border border-brand-blue/50 text-white px-4 py-1.5 font-bold text-sm mb-6 rounded-sm uppercase tracking-widest shadow-md backdrop-blur-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-blue" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
        Quality Workmanship Guaranteed
      </div>
      
      <h1 class="text-5xl md:text-7xl text-white mb-6 leading-[1.1] font-bold uppercase italic drop-shadow-2xl tracking-tight">
        The Last <span class="text-brand-blue underline decoration-white decoration-4 underline-offset-8">Flat Roof</span> You'll Ever Need.
      </h1>
      
      <p class="text-xl md:text-2xl text-gray-200 mb-10 max-w-2xl font-medium leading-relaxed drop-shadow-lg">
        Yorkshire's trusted contractors for <span class="text-white font-bold">Single-Ply Membranes</span>, <span class="text-white font-bold">Emergency Repairs</span>, and <span class="text-white font-bold">Full Replacements</span>. Built with a lifespan of up to 40+ years.
      </p>
      
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <button onclick="window.openQuoteModal()" class="cursor-pointer hover:-translate-y-1 bg-brand-blue text-white px-10 py-4 rounded font-bold text-xl transition-all duration-300 shadow-xl hover:shadow-2xl hover:shadow-brand-blue/40 uppercase tracking-widest border-2 border-brand-blue hover:bg-white hover:text-brand-blue hover:border-white">
          Free Quotation
        </button>
        
        <div class="flex flex-col">
          <span class="text-gray-300 font-bold uppercase tracking-wider text-sm mb-1 drop-shadow-md">Available 7 Days A Week</span>
          <div class="flex items-center gap-3 text-white">
            <span class="flex h-3 w-3 relative">
              <span class="animate-ping absolute h-3 w-3 rounded-full bg-[#25D366] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-[#25D366]"></span>
            </span>
            <span class="font-bold text-lg drop-shadow-md">Emergency Repairs Ready</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-bg {
    position: absolute;
    top: 0; 
    left: 0; 
    right: 0; 
    bottom: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    animation: kenburns 18s infinite linear;
    z-index: 0;
  }

  .bg-1 { animation-delay: 0s; opacity: 1; }
  .bg-2 { animation-delay: 6s; }
  .bg-3 { animation-delay: 12s; }

  @keyframes kenburns {
    0%   { opacity: 0; transform: scale(1); }
    10%  { opacity: 1; }
    33%  { opacity: 1; transform: scale(1.08); } 
    43%  { opacity: 0; transform: scale(1.1); }
    100% { opacity: 0; transform: scale(1); }
  }
</style>