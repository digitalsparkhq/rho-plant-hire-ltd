---
// src/components/FeaturedWork.astro
---

<section class="relative py-24 bg-brand-dark-blue px-6 border-b-4 border-brand-blue overflow-hidden">
  
  <div class="absolute inset-0 opacity-[0.05] bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
    
    <div class="w-full lg:w-1/2">
      <div class="inline-flex items-center gap-2 bg-brand-blue text-white px-4 py-1.5 font-bold text-sm mb-6 rounded-sm uppercase tracking-widest shadow-[4px_4px_0px_#0a0a0a]">
        Featured Project
      </div>
      
      <h2 class="text-4xl md:text-5xl font-bold text-white uppercase italic tracking-tight mb-6 leading-[1.1]">
        Recent Installation in <span class="text-brand-blue underline decoration-brand-white decoration-4 underline-offset-8">Anlaby, Hull</span>.
      </h2>
      
      <p class="text-lg md:text-xl text-gray-300 font-medium mb-6 leading-relaxed">
        Watch our team finish up another beautiful single-ply membrane roof. When we say our roofs are built to last, we mean it. 
      </p>

      <ul class="space-y-4 mb-8">
        <li class="flex items-center gap-3 text-brand-white font-bold text-lg">
          <svg class="w-6 h-6 text-brand-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          Flawless, watertight finish
        </li>
        <li class="flex items-center gap-3 text-brand-white font-bold text-lg">
          <svg class="w-6 h-6 text-brand-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          Fully stripped & re-decked
        </li>
        <li class="flex items-center gap-3 text-brand-white font-bold text-lg">
          <svg class="w-6 h-6 text-brand-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          Lifespan of up to 40+ Years!
        </li>
      </ul>

      <button onclick="window.openQuoteModal()" class="cursor-pointer bg-brand-white text-brand-black px-8 py-4 font-bold uppercase tracking-widest text-sm border-2 border-brand-white hover:bg-transparent hover:text-brand-white transition-all duration-300 shadow-[6px_6px_0px_#2a7bca] hover:shadow-[0px_0px_0px_#2a7bca] hover:translate-x-[6px] hover:translate-y-[6px]">
        Secure Your Roof Today
      </button>
    </div>

    <div class="w-full lg:w-1/2 flex justify-center lg:justify-end">
      <div class="relative w-full max-w-[560px] bg-brand-black p-2 border-4 border-brand-blue shadow-[12px_12px_0px_#0a0a0a]">
        <div class="relative w-full h-0 pb-[75%] overflow-hidden bg-black">
          <iframe 
            src="https://www.facebook.com/plugins/video.php?height=420&href=https%3A%2F%2Fwww.facebook.com%2Freel%2F1638092100866952%2F&show_text=false&width=560&t=0" 
            class="absolute top-0 left-0 w-full h-full border-none" 
            scrolling="no" 
            frameborder="0" 
            allowfullscreen="true" 
            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" 
            title="Recent Roofing Project Video">
          </iframe>
        </div>
        
        <div class="absolute -top-2 -left-2 w-4 h-4 bg-brand-white border-2 border-brand-black"></div>
        <div class="absolute -top-2 -right-2 w-4 h-4 bg-brand-white border-2 border-brand-black"></div>
        <div class="absolute -bottom-2 -left-2 w-4 h-4 bg-brand-white border-2 border-brand-black"></div>
        <div class="absolute -bottom-2 -right-2 w-4 h-4 bg-brand-white border-2 border-brand-black"></div>
      </div>
    </div>

  </div>
</section>