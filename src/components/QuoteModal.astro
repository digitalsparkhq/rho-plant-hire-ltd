---
// src/components/QuoteModal.astro
---

<dialog id="quote-modal" class="fixed inset-0 m-auto backdrop:bg-black/80 p-0 border-4 border-brand-blue shadow-[12px_12px_0px_#0a0a0a] w-full max-w-2xl max-h-[90vh] overflow-y-auto z-[100] bg-brand-white">
  <div class="p-6 md:p-8">
    
    <div class="flex justify-between items-center mb-6 border-b-2 border-gray-200 pb-4">
      <h2 class="text-3xl font-bold text-brand-black italic uppercase">Request a Free Quote</h2>
      <button id="close-modal" class="text-brand-black hover:text-brand-blue transition-colors cursor-pointer p-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <form id="quote-form" class="space-y-8">
      
      <div>
        <h3 class="text-sm font-bold text-brand-blue mb-4 uppercase tracking-widest flex items-center gap-2">
          <span class="w-6 h-px bg-brand-blue"></span> Step 1: Your Details
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="text" id="q-name" placeholder="Full Name *" required class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors font-medium text-brand-black placeholder-gray-500" />
          <input type="tel" id="q-phone" placeholder="Phone Number *" required class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors font-medium text-brand-black placeholder-gray-500" />
          <input type="text" id="q-address1" placeholder="Address Line 1 *" required class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors font-medium text-brand-black placeholder-gray-500" />
          <input type="text" id="q-address2" placeholder="Address Line 2" class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors font-medium text-brand-black placeholder-gray-500" />
          <input type="text" id="q-city" placeholder="City *" required class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors font-medium text-brand-black placeholder-gray-500" />
          <input type="text" id="q-postcode" placeholder="Postal Code *" required class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors font-medium text-brand-black placeholder-gray-500" />
        </div>
      </div>

      <div>
        <h3 class="text-sm font-bold text-brand-blue mb-4 uppercase tracking-widest flex items-center gap-2">
          <span class="w-6 h-px bg-brand-blue"></span> Step 2: Project Scope
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <select id="q-project" required class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors cursor-pointer font-medium text-brand-black">
            <option value="" disabled selected>Select Project Type *</option>
            <option value="Single-Ply Membrane">Single-Ply Membrane Installation</option>
            <option value="Emergency Leak Repair">Emergency Leak Repair</option>
            <option value="Garage Roof Replacement">Garage Roof Replacement</option>
            <option value="Dormer Waterproofing">Dormer Waterproofing</option>
            <option value="Commercial / Landlord">Commercial / Landlord Project</option>
            <option value="Other">Other</option>
          </select>
          
          <select id="q-timescale" required class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors cursor-pointer font-medium text-brand-black">
            <option value="" disabled selected>Timescale *</option>
            <option value="Immediate / Emergency">Immediate / Emergency</option>
            <option value="Within 1 Week">Within 1 Week</option>
            <option value="Within 2-4 Weeks">Within 2-4 Weeks</option>
            <option value="Flexible / Just planning">Flexible / Just planning</option>
          </select>
        </div>
        
        <textarea id="q-desc" rows="4" placeholder="Project Description (Tell us about the condition, size, or any specific concerns)" class="w-full border-2 border-brand-black p-3 bg-white focus:border-brand-blue focus:ring-0 outline-none transition-colors font-medium text-brand-black placeholder-gray-500"></textarea>
      </div>

      <button type="submit" class="w-full flex items-center justify-center gap-3 bg-[#25D366] text-white font-bold py-4 hover:bg-green-600 hover:-translate-y-1 transition-all duration-300 uppercase tracking-widest shadow-[6px_6px_0px_#0a0a0a] hover:shadow-[0px_0px_0px_#0a0a0a] cursor-pointer text-lg border-2 border-brand-black">
        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Send Details via WhatsApp
      </button>

    </form>
  </div>
</dialog>

<script>
  declare global {
    interface Window {
      openQuoteModal: () => void;
    }
  }

  const modal = document.getElementById('quote-modal') as HTMLDialogElement;
  const closeBtn = document.getElementById('close-modal');
  const quoteForm = document.getElementById('quote-form') as HTMLFormElement;

  window.openQuoteModal = () => {
    modal?.showModal();
    document.body.style.overflow = 'hidden'; 
  };

  const closeModal = () => {
    modal?.close();
    document.body.style.overflow = ''; 
  };

  closeBtn?.addEventListener('click', closeModal);
  
  modal?.addEventListener('click', (e) => {
    const dialogDimensions = modal.getBoundingClientRect();
    if (
      e.clientX < dialogDimensions.left ||
      e.clientX > dialogDimensions.right ||
      e.clientY < dialogDimensions.top ||
      e.clientY > dialogDimensions.bottom
    ) {
      closeModal();
    }
  });

  // WhatsApp Form Submission Logic
  quoteForm?.addEventListener('submit', (e) => {
    // Prevent the page from reloading
    e.preventDefault();

    // Gather all values from the form inputs
    const name = (document.getElementById('q-name') as HTMLInputElement).value;
    const phone = (document.getElementById('q-phone') as HTMLInputElement).value;
    const address1 = (document.getElementById('q-address1') as HTMLInputElement).value;
    const address2 = (document.getElementById('q-address2') as HTMLInputElement).value;
    const city = (document.getElementById('q-city') as HTMLInputElement).value;
    const postcode = (document.getElementById('q-postcode') as HTMLInputElement).value;
    const projectType = (document.getElementById('q-project') as HTMLSelectElement).value;
    const timescale = (document.getElementById('q-timescale') as HTMLSelectElement).value;
    const desc = (document.getElementById('q-desc') as HTMLTextAreaElement).value;

    // Filter out empty address fields to keep it clean
    const fullAddress = [address1, address2, city, postcode].filter(Boolean).join(', ');

    // Construct the WhatsApp message format
    const message = `*New Website Quote Request* 🏠

*Contact Details*
Name: ${name}
Phone: ${phone}
Address: ${fullAddress}

*Project Details*
Type: ${projectType}
Timescale: ${timescale}

*Description / Notes*
${desc ? desc : 'No additional details provided.'}`;

    // Target Phone Number (Without '+' or '0' at start, just country code + number)
    const targetWhatsAppNumber = "447949417242";

    // Encode the text so it works in a URL
    const encodedMessage = encodeURIComponent(message);
    
    // Create the deep link
    const whatsappUrl = `https://wa.me/${targetWhatsAppNumber}?text=${encodedMessage}`;

    // Open WhatsApp in a new tab/app
    window.open(whatsappUrl, '_blank');

    // Reset the form and close the modal after submitting
    quoteForm.reset();
    closeModal();
  });
</script>

<style>
  dialog::backdrop {
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(5px);
  }
</style>