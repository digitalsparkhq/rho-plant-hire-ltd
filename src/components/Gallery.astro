---
// src/components/Gallery.astro

const beforeAfterGalleries = [
  {
    title: "Single-Ply Membrane",
    before: "/images/before1.jpg",
    after: "/images/after1.jpg",
  },
  {
    title: "Flat Roof Waterproofing",
    before: "/images/before2.jpg",
    after: "/images/after2.jpg",
  },
  {
    title: "Dormer Waterproofing",
    before: "/images/before3.jpg",
    after: "/images/after3.jpg",
  }
];

const staticWorks = [
  "/images/work1.jpg",
  "/images/work2.jpg",
  "/images/work3.jpg",
  "/images/work4.jpg",
  "/images/work5.jpg",
  "/images/work6.jpg"
];
---

<section id="gallery" class="py-24 bg-brand-white text-brand-black px-6 border-b-4 border-brand-blue relative overflow-hidden">
  
  <div class="absolute inset-0 opacity-[0.03] bg-[url('https://www.transparenttextures.com/patterns/blueprint-grid.png')] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto z-10">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-brand-gray text-white px-4 py-1.5 font-bold text-sm mb-4 rounded-sm uppercase tracking-widest shadow-[4px_4px_0px_#0a0a0a]">
          Workmanship Proof
        </div>
        <h2 class="text-4xl md:text-5xl font-bold uppercase italic tracking-tight mb-4 text-brand-black">
          The <span class="text-brand-blue underline decoration-brand-black decoration-4 underline-offset-8">Transformation</span> Gallery
        </h2>
        <p class="text-lg text-gray-600 font-medium">
          Drag the sliders to see the heavy-duty results, or browse our recent installations across Yorkshire below. Click any image to expand.
        </p>
      </div>
      
      <button onclick="window.openQuoteModal()" class="cursor-pointer bg-brand-black text-white px-8 py-3 font-bold uppercase tracking-widest text-sm border-2 border-brand-black hover:bg-brand-blue hover:border-brand-blue transition-colors duration-300 shadow-[4px_4px_0px_#2a7bca] hover:shadow-[0px_0px_0px_#2a7bca] hover:translate-x-[4px] hover:translate-y-[4px]">
        Book Your Roof Inspection
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      {beforeAfterGalleries.map((item) => (
        <div class="flex flex-col gap-4">
          <h3 class="text-xl font-bold uppercase italic text-brand-black tracking-wide flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            <span class="truncate">{item.title}</span>
          </h3>
          
          <div class="ba-container relative w-full aspect-[4/3] border-4 border-brand-black shadow-[6px_6px_0px_#2a7bca] bg-brand-gray overflow-hidden select-none group">
            <img src={item.after} alt="After restoration" class="absolute inset-0 w-full h-full object-cover pointer-events-none" />
            <img src={item.before} alt="Before restoration" class="ba-before-image absolute inset-0 w-full h-full object-cover pointer-events-none z-10" style="clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);" />
            
            <div class="absolute top-3 left-3 z-20 bg-brand-black text-white px-2 py-1 text-[10px] md:text-xs font-bold uppercase tracking-widest border border-white/20 pointer-events-none shadow-md">
              [ Before ]
            </div>
            <div class="absolute top-3 right-3 z-0 bg-brand-blue text-white px-2 py-1 text-[10px] md:text-xs font-bold uppercase tracking-widest border border-brand-black pointer-events-none shadow-md">
              [ After ]
            </div>

            <input type="range" min="0" max="100" value="50" class="ba-slider absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-30 m-0 p-0" />
            
            <div class="ba-handle absolute top-0 bottom-0 left-[50%] w-1 bg-brand-blue z-20 pointer-events-none transform -translate-x-1/2 shadow-[0_0_10px_rgba(0,0,0,0.5)]">
              <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-8 h-8 md:w-10 md:h-10 bg-brand-black rounded-full border-[3px] md:border-4 border-brand-blue flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M8 9l4-4 4 4m0 6l-4 4-4-4" transform="rotate(90 12 12)" /></svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="border-t-2 border-gray-200 pt-16 mb-12 flex items-center justify-between">
      <h3 class="text-3xl font-bold uppercase italic text-brand-black">Recent <span class="text-brand-blue">Installations</span></h3>
      <div class="hidden md:flex gap-2">
        <span class="w-3 h-3 bg-brand-blue rounded-full"></span>
        <span class="w-3 h-3 bg-brand-black rounded-full"></span>
        <span class="w-3 h-3 bg-brand-gray rounded-full"></span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {staticWorks.map((imgSrc) => (
        <div class="static-work-item relative group aspect-[4/3] md:aspect-square lg:aspect-[4/3] border-4 border-brand-black overflow-hidden shadow-[4px_4px_0px_#2a7bca] hover:shadow-[0px_0px_0px_#2a7bca] hover:translate-x-[4px] hover:translate-y-[4px] transition-all duration-300 bg-brand-gray cursor-pointer">
          <img src={imgSrc} alt="Completed Flat Roofing Project" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 opacity-95 group-hover:opacity-100" />
          
          <div class="absolute inset-0 bg-brand-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <div class="bg-brand-blue text-white p-3 rounded-full transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 shadow-lg border-2 border-brand-black">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<dialog id="image-lightbox" class="fixed inset-0 m-auto bg-transparent border-none outline-none z-[100] w-full h-full max-w-none max-h-none p-0 overflow-hidden">
  
  <div id="lightbox-wrapper" class="w-full h-full flex items-center justify-center p-4 md:p-12 relative cursor-pointer">
    
    <button id="close-lightbox-btn" class="absolute top-4 right-4 md:top-8 md:right-8 bg-brand-blue text-white w-12 h-12 rounded-full flex items-center justify-center border-2 border-brand-black hover:bg-white hover:text-brand-black transition-colors cursor-pointer shadow-xl z-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    
    <img id="lightbox-img" src="" alt="Enlarged roof view" class="max-w-full max-h-full object-contain border-4 border-brand-black shadow-[12px_12px_0px_#000] bg-brand-black cursor-default z-10" />
    
  </div>
</dialog>

<script>
  // --- Before/After Slider Logic ---
  const containers = document.querySelectorAll('.ba-container');

  containers.forEach(container => {
    const slider = container.querySelector('.ba-slider') as HTMLInputElement;
    const beforeImage = container.querySelector('.ba-before-image') as HTMLImageElement;
    const handle = container.querySelector('.ba-handle') as HTMLElement;

    if (slider && beforeImage && handle) {
      slider.addEventListener('input', (e) => {
        const value = (e.target as HTMLInputElement).value;
        beforeImage.style.clipPath = `polygon(0 0, ${value}% 0, ${value}% 100%, 0 100%)`;
        handle.style.left = `${value}%`;
      });
    }
  });

  // --- Lightbox Logic ---
  const lightbox = document.getElementById('image-lightbox') as HTMLDialogElement;
  const lightboxWrapper = document.getElementById('lightbox-wrapper');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('close-lightbox-btn');
  const workItems = document.querySelectorAll('.static-work-item');

  // Open Lightbox
  workItems.forEach(item => {
    item.addEventListener('click', () => {
      const imgSrc = item.querySelector('img')?.src;
      if (imgSrc && lightboxImg && lightbox) {
        lightboxImg.src = imgSrc;
        lightbox.showModal();
        document.body.style.overflow = 'hidden'; // Stop background scrolling
      }
    });
  });

  // Close Lightbox function
  const closeLightbox = () => {
    if (lightbox) {
      lightbox.close();
      document.body.style.overflow = ''; // Restore background scrolling
    }
  };

  // Close via button
  closeBtn?.addEventListener('click', (e) => {
    e.stopPropagation(); // Prevents the click from hitting the wrapper
    closeLightbox();
  });

  // Close when clicking the dark background wrapper OR the dialog backdrop
  lightboxWrapper?.addEventListener('click', (e) => {
    // Check if they clicked the wrapper exactly (not the image)
    if (e.target === lightboxWrapper) {
      closeLightbox();
    }
  });
  
  // Failsafe for browsers that target the dialog itself on backdrop clicks
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });
</script>

<style>
  /* Darken and blur the background when the modal is open */
  dialog#image-lightbox::backdrop {
    background-color: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(5px);
  }
</style>