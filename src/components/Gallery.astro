---
// src/components/Gallery.astro

const fleetItems = [
  {
    src: "/images/work1.png",
    title: "Volvo 2.5T Excavator",
    caption: "Ready for any job — now available with a pecker attachment for breaking through tough ground with ease."
  },
  {
    src: "/images/work2.jpg",
    title: "Kubota 0.8T Micro Digger",
    caption: "Small but mighty — compact, powerful, and perfect for getting through narrow spaces where bigger machines just won't fit."
  }
];
---

<section id="ourfleet" class="py-24 bg-brand-white text-brand-black px-6 border-b-4 border-brand-blue relative overflow-hidden">
  
  <div class="absolute inset-0 opacity-[0.03] bg-[url('https://www.transparenttextures.com/patterns/blueprint-grid.png')] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto z-10">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-brand-slate text-white px-4 py-1.5 font-bold text-sm mb-4 rounded-sm uppercase tracking-widest shadow-[4px_4px_0px_#0a0a0a]">
          Equipment Showcase
        </div>
        <h2 class="text-4xl md:text-5xl font-bold uppercase italic tracking-tight mb-4 text-brand-black">
          Explore Our <span class="text-brand-blue underline decoration-brand-black decoration-4 underline-offset-8">Fleet</span>
        </h2>
        <p class="text-lg text-gray-600 font-medium">
          Well-maintained, reliable machinery ready to tackle your groundwork and landscaping projects. Click any image to expand.
        </p>
      </div>
      
      <button onclick="window.openQuoteModal()" class="cursor-pointer bg-brand-black text-white px-8 py-3 font-bold uppercase tracking-widest text-sm border-2 border-brand-black hover:bg-brand-blue hover:border-brand-blue transition-colors duration-300 shadow-[4px_4px_0px_#18528c] hover:shadow-[0px_0px_0px_#18528c] hover:translate-x-[4px] hover:translate-y-[4px]">
        Enquire About Hire
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {fleetItems.map((item) => (
        <div class="flex flex-col bg-white border-4 border-brand-black shadow-[8px_8px_0px_#18528c] transition-all duration-300 hover:shadow-[0px_0px_0px_#18528c] hover:translate-x-[8px] hover:translate-y-[8px]">
          
          <div class="static-work-item relative group aspect-[4/3] border-b-4 border-brand-black overflow-hidden bg-brand-gray cursor-pointer">
            <img src={item.src} alt={item.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 opacity-95 group-hover:opacity-100" />
            
            <div class="absolute inset-0 bg-brand-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <div class="bg-brand-blue text-white p-3 rounded-full transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 shadow-lg border-2 border-brand-black">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
              </div>
            </div>
          </div>

          <div class="p-6 md:p-8 flex-grow flex flex-col">
            <h3 class="text-2xl font-bold uppercase italic text-brand-black mb-3">
              {item.title}
            </h3>
            <p class="text-gray-600 font-medium leading-relaxed">
              {item.caption}
            </p>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<dialog id="image-lightbox" class="fixed inset-0 m-auto bg-transparent border-none outline-none z-[100] w-full h-full max-w-none max-h-none p-0 overflow-hidden">
  
  <div id="lightbox-wrapper" class="w-full h-full flex items-center justify-center p-4 md:p-12 relative cursor-pointer">
    
    <button id="close-lightbox-btn" class="absolute top-4 right-4 md:top-8 md:right-8 bg-brand-blue text-white w-12 h-12 rounded-full flex items-center justify-center border-2 border-brand-black hover:bg-white hover:text-brand-black transition-colors cursor-pointer shadow-xl z-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    
    <img id="lightbox-img" src="" alt="Enlarged machinery view" class="max-w-full max-h-full object-contain border-4 border-brand-black shadow-[12px_12px_0px_#000] bg-brand-black cursor-default z-10" />
    
  </div>
</dialog>

<script>
  // --- Lightbox Logic ---
  const lightbox = document.getElementById('image-lightbox') as HTMLDialogElement;
  const lightboxWrapper = document.getElementById('lightbox-wrapper');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('close-lightbox-btn');
  const workItems = document.querySelectorAll('.static-work-item');

  // Open Lightbox
  workItems.forEach(item => {
    item.addEventListener('click', () => {
      const imgSrc = item.querySelector('img')?.src;
      if (imgSrc && lightboxImg && lightbox) {
        lightboxImg.src = imgSrc;
        lightbox.showModal();
        document.body.style.overflow = 'hidden'; // Stop background scrolling
      }
    });
  });

  // Close Lightbox function
  const closeLightbox = () => {
    if (lightbox) {
      lightbox.close();
      document.body.style.overflow = ''; // Restore background scrolling
    }
  };

  // Close via button
  closeBtn?.addEventListener('click', (e) => {
    e.stopPropagation(); 
    closeLightbox();
  });

  // Close when clicking the dark background wrapper
  lightboxWrapper?.addEventListener('click', (e) => {
    if (e.target === lightboxWrapper) {
      closeLightbox();
    }
  });
  
  // Failsafe for browsers that target the dialog itself
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });
</script>

<style>
  /* Darken and blur the background when the modal is open */
  dialog#image-lightbox::backdrop {
    background-color: rgba(17, 24, 39, 0.9); /* brand-black */
    backdrop-filter: blur(5px);
  }
</style>