---
// src/components/About.astro
---

<section id="about" class="relative py-24 bg-brand-white px-6 border-b-4 border-brand-blue z-20 overflow-hidden">
  
  <div class="absolute inset-0 opacity-[0.03] bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    
    <div class="relative w-full max-w-md mx-auto lg:max-w-none">
      <div class="absolute inset-0 bg-brand-slate transform translate-x-6 translate-y-6 border-4 border-brand-black z-0"></div>
      
      <div class="relative z-10 border-4 border-brand-black bg-brand-black aspect-[4/5] md:aspect-square lg:aspect-[4/5] overflow-hidden group">
        <img 
          src="/images/about.jpg" 
          alt="RHO Plant Hire Equipment" 
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-90 group-hover:opacity-100"
        />
        
        <div class="absolute bottom-6 -left-2 bg-brand-blue text-white px-6 py-3 font-bold uppercase tracking-widest text-sm md:text-base border-2 border-brand-black shadow-[4px_4px_0px_#0a0a0a]">
          Based in West Yorkshire
        </div>
      </div>
    </div>

    <div>
      <div class="inline-flex items-center gap-2 bg-brand-slate text-white px-4 py-1.5 font-bold text-sm mb-6 rounded-sm uppercase tracking-widest shadow-[4px_4px_0px_#0a0a0a]">
        About Us
      </div>
      
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-black uppercase italic tracking-tight mb-8 leading-[1.1]">
        Reliable Machinery. <br/>
        <span class="text-brand-blue underline decoration-brand-black decoration-4 underline-offset-8">Local Plant Hire.</span>
      </h2>
      
      <p class="text-lg md:text-xl text-gray-700 font-medium mb-6 leading-relaxed">
        I’m excited to introduce my new local business, offering dependable and affordable plant hire services across West Yorkshire, Leeds, and the surrounding areas!
      </p>

      <p class="text-lg text-gray-600 font-medium mb-10 leading-relaxed">
        Whether you’re working on a commercial construction project, landscaping your garden, or tackling a DIY groundwork job, I’ve got a range of well-maintained equipment ready to help you get the job done safely and efficiently. As a local business, your support means a lot.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 border-l-4 border-brand-blue pl-6 py-2">
        <div class="flex items-center gap-3 font-bold text-brand-black uppercase text-sm tracking-wide">
          <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          Competitive Prices
        </div>
        <div class="flex items-center gap-3 font-bold text-brand-black uppercase text-sm tracking-wide">
          <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          Flexible Hire Options
        </div>
        <div class="flex items-center gap-3 font-bold text-brand-black uppercase text-sm tracking-wide">
          <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          Well-Maintained Fleet
        </div>
        <div class="flex items-center gap-3 font-bold text-brand-black uppercase text-sm tracking-wide">
          <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          Free Local Delivery
        </div>
      </div>

    </div>
  </div>
</section>