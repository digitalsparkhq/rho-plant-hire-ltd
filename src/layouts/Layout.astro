---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuoteModal from '../components/QuoteModal.astro'; // Ensures the form works on all pages
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "West Yorkshire's trusted local plant hire. Reliable Volvo excavators, Kubota micro diggers, and groundwork equipment available for flexible hire. Free local delivery." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-brand-white text-brand-black antialiased flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow">
      <slot />
    </main>
    
    <Footer />

    <QuoteModal />
  </body>
</html>

<style is:global>
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Oswald', sans-serif;
  }
</style>